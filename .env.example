# `.env` にはどちらか一方だけをコピーして使ってください。
# 開発用と運用用を同時に有効にしないでください。

# 開発 / ステージング用の例
# - ステージング専用の Bot token を使う
# - ステージング専用の SQLite ファイルを使う
# - GUILD_IDS にはステージング用サーバーの snowflake を 1 つ入れる
# - NODE_ENV は development のまま使う
#
# DISCORD_TOKEN=replace-with-staging-token
# DB_PATH=./staging.sqlite3
# GUILD_IDS=123456789012345678
# LOG_DIR=logs
# LOG_LEVEL=info
# DEBUG=false
# NODE_ENV=development

# 運用 / 本番用の例
# - 本番用の Bot token を使う
# - 本番用の SQLite ファイルを使う
# - 最初の確認段階では GUILD_IDS に本番サーバーの snowflake を入れる
# - global command へ切り替えるときは GUILD_IDS を空にする
# - NODE_ENV は production にする
#
# DISCORD_TOKEN=replace-with-production-token
# DB_PATH=./clanbattle.sqlite3
# GUILD_IDS=123456789012345678
# LOG_DIR=logs
# LOG_LEVEL=info
# DEBUG=false
# NODE_ENV=production

# いま使う設定のテンプレート
DISCORD_TOKEN=replace-me
DB_PATH=./staging.sqlite3
GUILD_IDS=123456789012345678
LOG_DIR=logs
LOG_LEVEL=info
DEBUG=false
NODE_ENV=development
